; mydomain.com zone
$ORIGIN mydomain.com.
$TTL 3600

@       IN      SOA     ns1.mydomain.com. admin.mydomain.com. (
                        2024010101 ; serial
                        3600       ; refresh
                        1800       ; retry
                        604800     ; expire
                        86400 )    ; minimum

@	3600	IN	A	192.168.3.100
@	3600	IN	A	192.168.3.100
test	3600	IN	A	192.168.1.100

; newdomain.com zone
$ORIGIN newdomain.com.
$TTL 3600

@       IN      SOA     ns1.newdomain.com. admin.newdomain.com. (
					2024010101 ; serial
					3600       ; refresh
					1800       ; retry
					604800     ; expire
					86400 )    ; minimum

@       IN      NS      ns1.newdomain.com.
@       IN      NS      ns2.newdomain.com.
www	3600	IN	A	192.168.1.200

